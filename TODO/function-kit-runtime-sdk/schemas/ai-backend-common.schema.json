{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "function-kit.ai-backend.common",
  "type": "object",
  "additionalProperties": true,
  "$defs": {
    "functionKitSurface": {
      "type": "string",
      "enum": [
        "inline",
        "panel",
        "editor"
      ]
    },
    "executionMode": {
      "type": "string",
      "enum": [
        "local-demo",
        "direct-model",
        "bounded-tool-calling-agent",
        "external-agent-adapter",
        "remote-openclaw"
      ]
    },
    "backendClass": {
      "type": "string",
      "enum": [
        "local-demo",
        "direct-model",
        "bounded-tool-calling-agent",
        "external-agent-adapter"
      ]
    },
    "latencyTier": {
      "type": "string",
      "enum": [
        "interactive",
        "balanced",
        "background"
      ]
    },
    "backendCapability": {
      "type": "string",
      "enum": [
        "structured-output",
        "tool-calling",
        "workspace-access",
        "memory-read",
        "memory-write",
        "citations",
        "streaming",
        "low-latency"
      ]
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "end": {
          "type": "integer",
          "minimum": 0
        },
        "text": {
          "type": "string"
        }
      }
    },
    "surroundingText": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "before": {
          "type": "string"
        },
        "after": {
          "type": "string"
        },
        "windowChars": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "personaContext": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "profileId": {
          "type": "string",
          "minLength": 1
        },
        "tone": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "values": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "backendHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preferredBackendClass": {
          "$ref": "#/$defs/backendClass"
        },
        "preferredAdapter": {
          "type": "string",
          "minLength": 1
        },
        "preferredModelFamily": {
          "type": "string",
          "minLength": 1
        },
        "executionMode": {
          "$ref": "#/$defs/executionMode"
        },
        "requiredCapabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/backendCapability"
          }
        },
        "latencyTier": {
          "$ref": "#/$defs/latencyTier"
        },
        "latencyBudgetMs": {
          "type": "integer",
          "minimum": 1
        },
        "allowFallbacks": {
          "type": "boolean"
        },
        "allowBackgroundPreparation": {
          "type": "boolean"
        },
        "requireStructuredJson": {
          "type": "boolean"
        },
        "maxToolCalls": {
          "type": "integer",
          "minimum": 0
        },
        "maxReasoningSteps": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "insert",
            "replace",
            "regenerate",
            "open-settings",
            "open-link",
            "tool-confirmation",
            "host-command"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        },
        "requiresConfirmation": {
          "type": "boolean"
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "tone": {
          "type": "string"
        },
        "risk": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "toolCall": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "tool"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "executed",
            "blocked"
          ]
        },
        "arguments": {
          "type": "object",
          "additionalProperties": true
        },
        "result": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "document",
            "url",
            "message",
            "memory"
          ]
        },
        "label": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        },
        "snippet": {
          "type": "string"
        }
      }
    },
    "backendError": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "retryable"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "latencyMs": {
          "type": "integer",
          "minimum": 0
        },
        "inputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "outputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "toolCalls": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
