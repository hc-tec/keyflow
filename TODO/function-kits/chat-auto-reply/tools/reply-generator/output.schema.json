{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reply-generator.output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidates"
  ],
  "properties": {
    "candidates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "text",
          "tone",
          "risk",
          "rationale"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "tone": {
            "type": "string"
          },
          "risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "rationale": {
            "type": "string"
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "type",
                "label"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "insert",
                    "replace",
                    "regenerate"
                  ]
                },
                "label": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "missing_context": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
