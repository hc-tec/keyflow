{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "function-kit.manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "entry",
    "runtimePermissions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "entry": {
      "type": "object",
      "additionalProperties": true
    },
    "triggers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "manual": {
          "type": "boolean"
        },
        "selectionRequired": {
          "type": "boolean"
        },
        "contextTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "triggers"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "triggers": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "manual",
                "selection",
                "clipboard"
              ]
            }
          },
          "requestedPayloads": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "selection.text",
                "selection.beforeCursor",
                "selection.afterCursor",
                "clipboard.text"
              ]
            },
            "uniqueItems": true
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "preferredPresentation": {
            "type": "string",
            "minLength": 1
          },
          "entry": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "discovery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pinnable": {
          "type": "boolean"
        },
        "recentEnabled": {
          "type": "boolean"
        },
        "launchMode": {
          "type": "string",
          "enum": [
            "quick-action",
            "panel-first",
            "hybrid"
          ]
        },
        "slash": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "commands": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "aliases": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "minQueryLength": {
              "type": "integer",
              "minimum": 0
            },
            "matchers": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "type",
                  "pattern"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "regex"
                  },
                  "pattern": {
                    "type": "string",
                    "minLength": 1
                  },
                  "weight": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "ranking": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "baseWeight": {
              "type": "number"
            },
            "recentBoost": {
              "type": "number"
            },
            "pinnedBoost": {
              "type": "number"
            },
            "contextBoost": {
              "type": "number"
            },
            "blockedPenalty": {
              "type": "number"
            }
          }
        }
      }
    },
    "ai": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executionMode"
      ],
      "properties": {
        "executionMode": {
          "$ref": "./ai-backend-common.schema.json#/$defs/executionMode"
        },
        "backendHints": {
          "$ref": "./ai-backend-common.schema.json#/$defs/backendHints"
        }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "host-proxy"
          ]
        },
        "allowAbsoluteUrls": {
          "type": "boolean"
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "needsActiveInputContext": {
          "type": "boolean"
        },
        "needsPersonaContext": {
          "type": "boolean"
        },
        "needsNetwork": {
          "type": "boolean"
        },
        "needsClipboard": {
          "type": "boolean"
        },
        "needsAiAccess": {
          "type": "boolean"
        }
      }
    },
    "runtimePermissions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "context.read",
          "input.insert",
          "input.replace",
          "input.commitImage",
          "input.observe.best_effort",
          "candidates.regenerate",
          "settings.open",
          "storage.read",
          "storage.write",
          "files.pick",
          "files.download",
          "panel.state.write",
          "runtime.message.send",
          "runtime.message.receive",
          "network.fetch",
          "ai.request",
          "kits.manage",
          "send.intercept.ime_action",
          "ai.agent.list",
          "ai.agent.run"
        ]
      }
    },
    "hostBridge": {
      "type": "object",
      "additionalProperties": true
    },
    "agent": {
      "type": "object",
      "additionalProperties": true
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
