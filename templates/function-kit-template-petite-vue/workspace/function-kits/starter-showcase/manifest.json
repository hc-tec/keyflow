{
  "id": "starter-showcase",
  "name": "Starter Showcase",
  "version": "0.1.0",
  "description": "A petite-vue starter wired to vendored runtime assets and a KitStudio-ready landing-page preview.",
  "icons": {
    "64": "icons/starter-showcase.svg"
  },
  "platforms": [
    "windows",
    "android"
  ],
  "entry": {
    "type": "browser-app",
    "bundle": {
      "html": "ui/app/index.html",
      "script": "ui/app/main.js",
      "style": "ui/app/styles.css"
    },
    "surfaces": {
      "windows": {
        "preferred": "side-panel",
        "fallback": "popup",
        "minWidth": 360
      },
      "android": {
        "preferred": "bottom-sheet",
        "fallback": "full-screen",
        "peekHeightDp": 300
      }
    }
  },
  "triggers": {
    "manual": true,
    "selectionRequired": false,
    "contextTypes": [
      "message-compose",
      "generic-text"
    ]
  },
  "discovery": {
    "pinnable": true,
    "recentEnabled": true,
    "launchMode": "panel-first",
    "slash": {
      "enabled": true,
      "commands": [
        "starter"
      ],
      "aliases": [
        "launchpad",
        "template"
      ],
      "tags": [
        "starter",
        "template",
        "petite-vue"
      ]
    }
  },
  "ai": {
    "executionMode": "none",
    "backendHints": {
      "preferredBackendClass": "none",
      "requiredCapabilities": [],
      "latencyTier": "instant",
      "latencyBudgetMs": 120,
      "allowFallbacks": false,
      "allowBackgroundPreparation": false,
      "requireStructuredJson": false,
      "maxToolCalls": 0,
      "maxReasoningSteps": 0,
      "notes": [
        "This starter is local-first and demonstrates the browser runtime surface before you wire any model backend."
      ]
    }
  },
  "network": {
    "mode": "disabled",
    "allowAbsoluteUrls": false
  },
  "permissions": {
    "needsActiveInputContext": true,
    "needsPersonaContext": false,
    "needsNetwork": false,
    "needsAiAccess": false
  },
  "runtimePermissions": [
    "context.read",
    "input.insert",
    "input.replace",
    "settings.open",
    "storage.read",
    "storage.write"
  ]
}
