{
  "name": "@keyflow2/function-kit-template-preview-rewrite",
  "version": "0.1.0",
  "description": "Starter workspace for Keyflow Function Kits that generate AI text previews before replacing input.",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    ".gitignore",
    "docs",
    "workspace",
    "scripts",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "keyflow",
    "function-kit",
    "starter",
    "template",
    "preview",
    "rewrite",
    "ai",
    "petite-vue",
    "kitstudio",
    "ime"
  ],
  "scripts": {
    "open:kitstudio": "node ./scripts/open-in-kitstudio.mjs",
    "rename:starter": "node ./scripts/rename-starter.mjs",
    "doctor": "node ./scripts/doctor.mjs",
    "pack:zip": "node ./scripts/pack-kit-zip.mjs",
    "pack:npm": "node ./scripts/pack-kit-npm.mjs",
    "publish:npm": "node ./scripts/publish-kit-npm.mjs",
    "catalog:check": "node ./scripts/catalog-check.mjs",
    "catalog:entry": "node ./scripts/generate-catalog-entry.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hc-tec/keyflow.git"
  },
  "bugs": {
    "url": "https://github.com/hc-tec/keyflow/issues"
  },
  "homepage": "https://github.com/hc-tec/keyflow#readme",
  "keyflow": {
    "kind": "function-kit-starter",
    "template": "preview-rewrite",
    "defaultKitId": "preview-rewrite-starter",
    "defaultMountRoot": "workspace/function-kits"
  }
}
